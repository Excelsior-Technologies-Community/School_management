{
  "openapi": "3.0.0",
  "info": {
    "title": "School Management System API Documentation",
    "version": "1.0.0",
    "description": "Interactive API playground for managing multi-tenant schools, staff, and authentication matrices."
  },
  "servers": [
    {
      "url": "http://localhost:5000",
      "description": "Development Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Enter your JWT token in the format: Bearer <token>"
      }
    }
  },
  "paths": {
    "/api/auth/login": {
      "post": {
        "summary": "Authenticate user and fetch security access token",
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "example": "name@example.com"
                  },
                  "password": {
                    "type": "string",
                    "example": "12345678"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authentication successful, returns user object and payload token."
          },
          "401": {
            "description": "Invalid Email or Password configuration errors."
          },
          "403": {
            "description": "Account not activated validation roadblock."
          },
          "500": {
            "description": "Internal Database Engine error anomaly."
          }
        }
      }
    },
    "/api/auth/setup-password": {
      "post": {
        "summary": "Initialize private password via random onboarding token",
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "token",
                  "password"
                ],
                "properties": {
                  "token": {
                    "type": "string",
                    "example": "a1b2c3d4e5f6g7h8..."
                  },
                  "password": {
                    "type": "string",
                    "example": "securepassword123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password initialized successfully."
          },
          "400": {
            "description": "Missing parameters or invalid/expired invitation token configuration."
          }
        }
      }
    },
    "/api/super/create-school": {
      "post": {
        "summary": "Provision a new school entity and its primary tenant administrator account",
        "tags": [
          "Super Admin"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "schoolName",
                  "address",
                  "adminName",
                  "adminEmail"
                ],
                "properties": {
                  "schoolName": {
                    "type": "string",
                    "example": "Name"
                  },
                  "address": {
                    "type": "string",
                    "example": "sp rind road, Ahmedabad"
                  },
                  "adminName": {
                    "type": "string",
                    "example": "Admin"
                  },
                  "adminEmail": {
                    "type": "string",
                    "example": "admin@gmail.com"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "School created and secure verification email dispatched smoothly."
          },
          "400": {
            "description": "Incomplete validation parameter error fields."
          },
          "401": {
            "description": "Missing or malformed Authorization core header."
          },
          "403": {
            "description": "Access Denied: User role lack super_admin clearance tiers."
          },
          "500": {
            "description": "Stored Procedure database transaction error or rollback exception."
          }
        }
      }
    },
    "/api/super/school-admins": {
      "get": {
        "summary": "Fetch data directory matching all registered schools alongside their active/pending admins",
        "tags": [
          "Super Admin"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Directory collection fetched successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "count": {
                      "type": "integer",
                      "example": 1
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "school_id": {
                            "type": "integer",
                            "example": 1
                          },
                          "school_name": {
                            "type": "string",
                            "example": "Name"
                          },
                          "school_address": {
                            "type": "string",
                            "example": "sp ring road,ahmedabad"
                          },
                          "school_created_at": {
                            "type": "string",
                            "example": "2026-05-28T09:30:00.000Z"
                          },
                          "admin_id": {
                            "type": "integer",
                            "example": 5
                          },
                          "admin_name": {
                            "type": "string",
                            "example": "Admin"
                          },
                          "admin_email": {
                            "type": "string",
                            "example": "admin@gmail.com"
                          },
                          "invitation_token": {
                            "type": "string",
                            "nullable": true,
                            "example": null
                          },
                          "account_status": {
                            "type": "string",
                            "example": "Active"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized token footprint check error."
          },
          "403": {
            "description": "Forbidden tier permissions context access barrier."
          }
        }
      }
    },
    "/api/school/add-member": {
      "post": {
        "summary": "Provision a new institutional staff or teacher record",
        "tags": [
          "School Admin"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "roleId",
                  "name",
                  "email",
                  "department"
                ],
                "properties": {
                  "roleId": {
                    "type": "integer",
                    "example": 3,
                    "description": "The relational ID of the role (e.g., 2 for school_admin, 3 for staff_member)"
                  },
                  "name": {
                    "type": "string",
                    "example": "Prof"
                  },
                  "email": {
                    "type": "string",
                    "example": "prof@gmail.com"
                  },
                  "department": {
                    "type": "string",
                    "example": "Computer Science"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Staff member committed to system database grid successfully."
          },
          "400": {
            "description": "Validation Error: Incomplete request payload or missing token properties."
          },
          "500": {
            "description": "Database signal rejection or duplicate unique email constraint violation."
          }
        }
      }
    },
    "/api/school/list-members": {
      "get": {
        "summary": "Fetch directory list matching all registered staff within the admin's school",
        "tags": [
          "School Admin"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Isolated institutional directory fetched successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "count": {
                      "type": "integer",
                      "example": 1
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "staff_id": {
                            "type": "integer",
                            "example": 12
                          },
                          "name": {
                            "type": "string",
                            "example": "Prof"
                          },
                          "email": {
                            "type": "string",
                            "example": "prof@gmail.com"
                          },
                          "department": {
                            "type": "string",
                            "example": "Computer Science"
                          },
                          "role_id": {
                            "type": "integer",
                            "example": 3
                          },
                          "role_name": {
                            "type": "string",
                            "example": "staff_member"
                          },
                          "created_at": {
                            "type": "string",
                            "example": "2026-05-29T06:15:00.000Z"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized: Invalid or missing token profile context."
          },
          "403": {
            "description": "Access Denied: Only users holding school_admin privileges can invoke this directory view."
          }
        }
      }
    },
    "/api/school/update-member": {
      "put": {
        "summary": "Modify profile details of an existing institutional staff member",
        "tags": [
          "School Admin"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "staffId",
                  "roleId",
                  "name",
                  "email",
                  "department"
                ],
                "properties": {
                  "staffId": {
                    "type": "integer",
                    "example": 12
                  },
                  "roleId": {
                    "type": "integer",
                    "example": 3
                  },
                  "name": {
                    "type": "string",
                    "example": "Prof"
                  },
                  "email": {
                    "type": "string",
                    "example": "prof123@gmail.com"
                  },
                  "department": {
                    "type": "string",
                    "example": "Information Technology"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Staff profile row structural attributes altered successfully."
          },
          "400": {
            "description": "Incomplete request body payload variables configuration."
          },
          "500": {
            "description": "Access Denied / Not Found or Target resource ownership check mismatch failure."
          }
        }
      }
    },
    "/api/school/remove/{staffId}": {
      "delete": {
        "summary": "Permanently purge an isolated staff record from the institutional registry",
        "tags": [
          "School Admin"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "staffId",
            "in": "path",
            "required": true,
            "description": "The exact database primary key index string identifier of the staff record row to be purged",
            "schema": {
              "type": "integer",
              "example": 12
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Target profile dropped from relational database matrix schema."
          },
          "400": {
            "description": "Missing required URL query context identification indices strings."
          },
          "500": {
            "description": "Access Denied: Record not found or belongs to a different school instance database."
          }
        }
      }
    },
    "/api/school/payroll/all": {
      "get": {
        "summary": "Fetch master payroll list matching staff profiles and salary configurations",
        "tags": ["School Admin Payroll"],
        "security": [{"bearerAuth": []}],
        "responses": {
          "200": { "description": "Payroll report generated." }
        }
      }
    },
    "/api/school/payroll/assign": {
      "post": {
        "summary": "Attach a new base compensation index mapping layer to a staff profile",
        "tags": ["School Admin Payroll"],
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["staffId", "baseSalary"],
                "properties": {
                  "staffId": { "type": "integer", "example": 5 },
                  "baseSalary": { "type": "number", "example": 75000.50 }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Salary mapped." }
        }
      }
    },
    "/api/school/payroll/update": {
      "put": {
        "summary": "Alter base salary data row configurations matching a staff parameter",
        "tags": ["School Admin Payroll"],
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["staffId", "baseSalary"],
                "properties": {
                  "staffId": { "type": "integer", "example": 5 },
                  "baseSalary": { "type": "number", "example": 82000.00 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Salary values shifted successfully." }
        }
      }
    },
    "/api/school/payroll/clear/{staffId}": {
      "delete": {
        "summary": "Purge salary entry rows away from structural relational charts",
        "tags": ["School Admin Payroll"],
        "security": [{"bearerAuth": []}],
        "parameters": [
          { "name": "staffId", "in": "path", "required": true, "schema": { "type": "integer", "example": 5 } }
        ],
        "responses": {
          "200": { "description": "Ledger entry cleared out cleanly." }
        }
      }
    }
  }
}